APP_NAME=Note Organizer
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-here

DATABASE_URL=sqlite:///./data/notes.db

DATA_DIR=./data
IMAGES_DIR=./data/images
MARKDOWN_DIR=./data/markdown
CARDS_DIR=./data/cards

OCR_LANG=ch

OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4

LOG_LEVEL=INFO

ZHIPU_API_KEY=xxx

AI_REFINE_OCR=true

USE_STRUCTURE_V3=true
STRUCTURE_USE_FORMULA=true
STRUCTURE_USE_TABLE=true
STRUCTURE_FORMULA_MODEL=PP-FormulaNet_plus-M
STRUCTURE_DEVICE=gpu